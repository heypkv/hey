{
  "hey_packs": 0,
  "packs": {
    "postgres": {
      "pack": "postgres",
      "driver": "archive-exec",
      "kind": "service",
      "versions": {
        "16.9.0": {
          "artifacts": {
            "windows_amd64": {
              "url": "https://get.enterprisedb.com/postgresql/postgresql-16.9-1-windows-x64-binaries.zip",
              "sha256": "304eb7dab70717015c4fd09986122e470d53a57a3a2b443d31e2c1d83d88db88",
              "bin_subdir": "pgsql/bin"
            },
            "darwin_amd64": {
              "url": "https://get.enterprisedb.com/postgresql/postgresql-16.9-1-osx-binaries.zip",
              "sha256": "6c13e2ca74ee3116af4c0e47562cfdebf3c7e974e0b22578e7c25db09b40ef2d",
              "bin_subdir": "pgsql/bin"
            }
          }
        }
      },
      "init": [
        "{bin}/initdb -D {data} -U {user} --pwfile {pwfile} -E UTF8 -A scram-sha-256"
      ],
      "start": "{bin}/postgres -D {data} -p {port} -c listen_addresses=127.0.0.1",
      "ready": { "command": "{bin}/pg_isready -h 127.0.0.1 -p {port} -U {user}", "timeout_seconds": 60 },
      "conn": "postgresql://{user}:{password}@127.0.0.1:{port}/postgres",
      "stop": { "command": "{bin}/pg_ctl stop -D {data} -m fast", "signal": "term", "grace_seconds": 20 }
    }
  }
}
